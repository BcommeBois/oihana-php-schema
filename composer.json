{
    "name" : "oihana/php-schema" ,
    "type" : "library" ,
    "description" : "The Oihana PHP Schema library" ,
    "keywords" : [ "php" , "schema" ] ,
    "homepage" : "https://github.com/BcommeBois/oihana-php-schema" ,
    "license" : [ "MPL-2.0" ] ,
    "authors" : [
        {
            "name" : "Marc Alcaraz" ,
            "email" : "marc@ooop.fr" ,
            "homepage" : "https://www.ooop.fr" ,
            "role" : "Project Founder, Lead Developer."
        }
    ],
    "support": {
        "email": "marc@ooop.fr"
    },
    "scripts": {
        "doc": "rm -rf docs && mkdir docs && cp -r assets docs/assets && ./vendor/bin/phpdoc -c phpdoc.xml -v" ,
        "test": "./vendor/bin/phpunit",
        "coverage": "XDEBUG_MODE=coverage ./vendor/bin/phpunit --coverage-text --coverage-clover build/coverage/clover.xml --coverage-html build/coverage/html" ,
        "coverage:md": [
            "@coverage" ,
            "php tools/clover-to-markdown.php build/coverage/clover.xml build/coverage/COVERAGE.md"
        ],
        "schemas:all": "php bin/generate-schemas.php",
        "schema:place": "php bin/generate-schema.php org\\schema\\Place"
    },
    "autoload" :
    {
        "psr-4" :
        {
            "com\\progress\\": "src/com/progress" ,
            "org\\schema\\": "src/org/schema" ,
            "xyz\\oihana\\": "src/xyz/oihana"
        } ,
        "files" :
        [
            "src/org/schema/helpers/hydrate/hydrateAdditionalProperty.php" ,
            "src/org/schema/helpers/hydrate/hydrateContactPoint.php" ,
            "src/org/schema/helpers/hydrate/hydrateDefinedTerm.php" ,
            "src/org/schema/helpers/hydrate/hydrateGeoCoordinates.php" ,
            "src/org/schema/helpers/hydrate/hydrateOfferPurchase.php" ,
            "src/org/schema/helpers/hydrate/hydratePostalAddress.php" ,
            "src/xyz/oihana/schema/helpers/hydrate/hydrateAggregateOffer.php" ,
            "src/xyz/oihana/schema/helpers/hydrate/hydrateCustomer.php" ,
            "src/xyz/oihana/schema/helpers/hydrate/hydrateCustomerEmployee.php" ,
            "src/xyz/oihana/schema/helpers/hydrate/hydrateCustomerSite.php" ,
            "src/xyz/oihana/schema/helpers/hydrate/hydrateStockLevel.php" ,
            "src/xyz/oihana/schema/helpers/hydrate/hydrateWarehouse.php" ,
            "src/xyz/oihana/schema/helpers/pivots/customerKey.php" ,
            "src/xyz/oihana/schema/helpers/pivots/sellerKey.php" ,
            "src/xyz/oihana/schema/helpers/pivots/sellerKeys.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "tests\\" : "tests"
        }
    },
    "require": {
        "php": ">=8.4",
        "oihana/php-core": "dev-main",
        "oihana/php-enums": "dev-main",
        "oihana/php-reflect": "dev-main",
        "oihana/php-standards": "dev-main"
    },
    "require-dev": {
        "phpunit/phpunit": "^13",
        "nunomaduro/collision": "^8.8",
        "phpdocumentor/shim": "^3.8"
    },
    "config": {
        "allow-plugins": {
            "phpdocumentor/shim": true
        }
    }
}
